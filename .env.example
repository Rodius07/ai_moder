# Create your bot with @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional. Send borderline cases to this chat. Can be a private admin chat,
# group, or channel id where the bot can send messages.
ADMIN_CHAT_ID=

# Optional. If empty, the bot will use rule-based moderation only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-mini

# For OpenRouter use:
# OPENAI_API_KEY=your_openrouter_key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-5-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=TG Guard Bot
CHAT_RULES_PATH=chat_rules.md
DATA_PATH=data/bot_state.json

# Moderation behavior.
DELETE_HIGH_CONFIDENCE=true
WARN_IN_CHAT=true
CONTEXT_MESSAGE_LIMIT=10
ENABLE_LOCAL_TRANSCRIPTION=true
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
MAX_TRANSCRIPTION_FILE_MB=25
MAX_WARNINGS_BEFORE_MUTE=3
MUTE_MINUTES=30

# Rule tuning.
MAX_MESSAGE_LENGTH=1800
FLOOD_WINDOW_SECONDS=12
FLOOD_MAX_MESSAGES=6
BLOCKED_WORDS=казино,ставки,наркотики
BLOCKED_LINK_DOMAINS=
