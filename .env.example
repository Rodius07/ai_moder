# Create your bot with @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional. Send borderline cases to this chat. Can be a private admin chat,
# group, or channel id where the bot can send messages.
ADMIN_CHAT_ID=

# Optional. If empty, the bot will use rule-based moderation only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-mini
OPENAI_MODERATION_MODEL=google/gemini-2.0-flash-lite-001

# For OpenRouter use:
# OPENAI_API_KEY=your_openrouter_key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-5-mini
# OPENAI_MODERATION_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=TG Guard Bot
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENROUTER_IMAGE_ASPECT_RATIO=1:1
OPENROUTER_IMAGE_SIZE=1K
OPENROUTER_VIDEO_MODEL=x-ai/grok-imagine-video
OPENROUTER_VIDEO_ASPECT_RATIO=16:9
OPENROUTER_VIDEO_DURATION=5
OPENROUTER_VIDEO_RESOLUTION=720p
CHAT_RULES_PATH=chat_rules.md
DATA_PATH=data/bot_state.json
SETTINGS_WEB_URL=https://89-124-122-2.sslip.io/moder-settings/
SETTINGS_WEB_HOST=127.0.0.1
SETTINGS_WEB_PORT=8081
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STT_MODEL_ID=scribe_v2

# Moderation behavior.
DELETE_HIGH_CONFIDENCE=true
WARN_IN_CHAT=true
CONTEXT_MESSAGE_LIMIT=10
ENABLE_LOCAL_TRANSCRIPTION=true
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
MAX_TRANSCRIPTION_FILE_MB=25
MAX_SOCIAL_VIDEO_FILE_MB=48
MAX_WARNINGS_BEFORE_MUTE=3
MUTE_MINUTES=30

# Rule tuning.
MAX_MESSAGE_LENGTH=1800
FLOOD_WINDOW_SECONDS=12
FLOOD_MAX_MESSAGES=6
BLOCKED_WORDS=казино,ставки,наркотики
BLOCKED_LINK_DOMAINS=
